{
    "name": "waaseyaa/path",
    "description": "URL path aliases and routing integration for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"}
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/entity": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Path\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Path\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": ["Waaseyaa\\Path\\PathServiceProvider"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
